---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import research from '../content/research.json';
import news from '../content/news.json';
import resources from '../content/resources.json';
const base = import.meta.env.BASE_URL;
const recentSoftware = resources.filter(r => r.type === 'Software').slice(0, 2);
const recentData = resources.filter(r => r.type === 'Dataset' || r.type === 'Model').slice(0, 2);

function assetUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
function itemLink(item: { github?: string }) {
  return item.github || `${base}resources/`;
}
---

<BaseLayout>

  <!-- ============================================================
       HERO — Clean, academic, honest about being new
  ============================================================ -->
  <section class="hero">
    <canvas id="particles" class="hero-canvas"></canvas>
    <div class="container hero-content">
      <h1 class="hero-title reveal">
        Data-centric AI for Healthcare and Medicine
      </h1>
      <p class="hero-desc reveal" style="transition-delay:0.1s">
        The Tushar Lab is a newly established research group at the University of Arizona
        advancing data-centric AI for healthcare and medicine through data discovery,
        intelligent tools, and the integration of clinical, simulated, and synthetic datasets.
      </p>
      <p class="hero-dept reveal" style="transition-delay:0.15s">
        Department of Radiology and Imaging Sciences &middot; University of Arizona
      </p>
      <div class="hero-actions reveal" style="transition-delay:0.2s">
        <a href={`${base}research/`} class="btn btn-primary">Our Research</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ============================================================
       MISSION & RESEARCH — Combined section
  ============================================================ -->
  <section class="section mission-section">
    <div class="container mission-grid">
      <div class="mission-left reveal">
        <p class="section-label">About the Lab</p>
        <h2>Our Mission</h2>
      </div>
      <div class="mission-right reveal" style="transition-delay:0.1s">
        <p class="mission-text">
          We are building a research program around a central question:
          <em>how do we develop AI for healthcare and medicine that is trustworthy,
          rigorously evaluated, and grounded in clinical needs?</em>
        </p>
        <p class="mission-text">
          Our work combines data-centric AI, intelligent tools, and clinical, simulated,
          and synthetic data to move from data to discovery in ways that better support
          healthcare professionals, reduce workload, and strengthen reliability in practice.
        </p>
        <p class="mission-text">
          As a newly established and growing lab, we welcome collaboration with researchers,
          students, and partners who share an interest in trustworthy, reproducible,
          and clinically grounded AI.
        </p>
      </div>
    </div>
    <div class="container research-container">
      <div class="research-grid-v2">
        {research.map((r, i) => (
          <a href={`${base}research/`} class="research-card-v2 reveal" style={`transition-delay:${i * 0.08}s`}>
            <div class={`rc-icon-wrap-v2 rc-icon-theme-${i}`}>
              <svg class="rc-icon-v2" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {r.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                {r.icon === 'brain' && <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z M9 22h6"/>}
                {r.icon === 'monitor' && <><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></>}
                {r.icon === 'layers' && <><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></>}
              </svg>
            </div>
            <h3>{r.title}</h3>
            <p>{r.short}</p>
            <span class="rc-link-v2">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       RECENTLY SHARED — Software & Data
  ============================================================ -->
  <section class="section recently-shared-section">
    <div class="container">
      <div class="shared-grid reveal">
        <!-- Recently Shared Software -->
        <div class="shared-column">
          <h2 class="shared-heading">Recently Shared Software</h2>
          <a href={`${base}resources/`} class="shared-view-all">✦ View All Software</a>
          {recentSoftware.map(item => (
            <div class="shared-item">
              <h3 class="shared-item-title">
                <a href={itemLink(item)}>{item.title}</a>
              </h3>
              <div class="shared-item-body">
                {item.image && (
                  <img src={assetUrl(item.image)} alt={item.title} class="shared-item-thumb" />
                )}
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Recently Shared Data -->
        <div class="shared-column">
          <h2 class="shared-heading">Recently Shared Data</h2>
          <a href={`${base}resources/`} class="shared-view-all">✦ View All Data</a>
          {recentData.map(item => (
            <div class="shared-item">
              <h3 class="shared-item-title">
                <a href={itemLink(item)}>{item.title}</a>
              </h3>
              <div class="shared-item-body">
                {item.image && (
                  <img src={assetUrl(item.image)} alt={item.title} class="shared-item-thumb" />
                )}
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       NEWS — Latest updates
  ============================================================ -->
  <section class="section news-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>News</h2>
        <a href={`${base}news/`} class="shared-view-all">✦ View All News</a>
      </div>
      <div class="news-cards-grid">
        {news.slice(0, 3).map(n => (
          <a href={`${base}news/${n.id}/`} class="news-card-v2 reveal">
            {n.image && (
              <div class="news-card-image">
                <img src={assetUrl(n.image)} alt={n.title} />
              </div>
            )}
            <div class="news-card-body">
              <h4 class="news-card-title">{n.title}</h4>
              <p class="news-card-summary">{n.summary}</p>
              <span class="news-card-read-more">✦ Read More</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---- Hero ---- */
.hero {
  position: relative;
  padding: var(--space-3xl) 0 var(--space-2xl);
  background: linear-gradient(180deg, #F8FAFF 0%, var(--white) 100%);
  overflow: hidden;
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-accent {
  position: absolute;
  top: 0;
  right: 0;
  width: 45%;
  height: 100%;
  background: radial-gradient(ellipse at 70% 40%, rgba(12, 35, 75, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 720px;
}

.hero-title {
  color: var(--gray-900);
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  line-height: 1.15;
  margin-bottom: var(--space-md);
  letter-spacing: -0.025em;
}

.hero-desc {
  color: var(--text-secondary);
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 620px;
  margin-bottom: var(--space-md);
  font-weight: 400;
}

.hero-dept {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--gray-400);
  margin-bottom: var(--space-lg);
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Mission ---- */
.mission-section {
  border-top: 1px solid var(--gray-100);
}

.mission-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-xl);
  align-items: start;
}
.mission-text {
  font-size: 1.02rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}
.mission-text em {
  font-style: italic;
  color: var(--gray-800);
  font-weight: 500;
}

.research-container {
  margin-top: var(--space-xl);
}

/* ---- Research cards v2 ---- */
.research-grid-v2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-lg);
}
.research-card-v2 {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, transform 0.35s ease;
  position: relative;
  overflow: hidden;
}
.research-card-v2::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.research-card-v2:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(171, 5, 32, 0.15);
  transform: translateY(-4px);
}
.research-card-v2:hover::before {
  opacity: 1;
}
.rc-icon-wrap-v2 {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  margin-bottom: var(--space-md);
  transition: transform 0.3s ease;
}
.research-card-v2:hover .rc-icon-wrap-v2 {
  transform: scale(1.08);
}
/* Themed icon backgrounds and top accents */
.rc-icon-theme-0 { background: rgba(171, 5, 32, 0.08); color: var(--primary); }
.rc-icon-theme-1 { background: rgba(12, 35, 75, 0.08); color: var(--navy); }
.rc-icon-theme-2 { background: rgba(37, 87, 167, 0.1); color: #2557A7; }
.rc-icon-theme-3 { background: rgba(139, 0, 21, 0.08); color: var(--primary-dark); }
.research-card-v2:nth-child(1)::before { background: linear-gradient(90deg, var(--primary), var(--primary-dark)); }
.research-card-v2:nth-child(2)::before { background: linear-gradient(90deg, var(--navy), var(--navy-light)); }
.research-card-v2:nth-child(3)::before { background: linear-gradient(90deg, #2557A7, var(--navy)); }
.research-card-v2:nth-child(4)::before { background: linear-gradient(90deg, var(--primary-dark), var(--primary)); }

.rc-icon-v2 {
  width: 32px;
  height: 32px;
}
.research-card-v2 h3 {
  color: var(--gray-900);
  margin-bottom: 0.6rem;
  font-size: 1.15rem;
}
.research-card-v2 p {
  font-size: 0.92rem;
  line-height: 1.7;
  flex: 1;
}
.rc-link-v2 {
  display: inline-flex;
  align-items: center;
  margin-top: var(--space-md);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--primary);
  transition: gap 0.2s ease;
  gap: 0.25rem;
}
.research-card-v2:hover .rc-link-v2 {
  gap: 0.5rem;
}

@media (max-width: 700px) {
  .research-grid-v2 { grid-template-columns: 1fr; }
}

/* ---- News ---- */
.news-cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}

.news-card-v2 {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  border: 1px solid var(--gray-200);
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.news-card-v2:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.news-card-image {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--gray-100);
}
.news-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.news-card-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.news-card-title {
  font-size: 1rem;
  color: var(--navy);
  line-height: 1.4;
}

.news-card-summary {
  font-size: 0.875rem;
  line-height: 1.65;
  flex: 1;
}

.news-card-read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--navy);
  margin-top: var(--space-sm);
}
.news-card-v2:hover .news-card-read-more {
  color: var(--primary);
}

/* ---- Recently Shared ---- */
.recently-shared-section {
  border-top: 1px solid var(--gray-200);
  border-bottom: 1px solid var(--gray-200);
  background: var(--white);
}

.shared-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
}

.shared-heading {
  font-size: clamp(1.3rem, 2.5vw, 1.6rem);
  color: var(--gray-900);
  margin-bottom: 0.5rem;
}

.shared-view-all {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--navy);
  text-decoration: none;
  margin-bottom: var(--space-lg);
}
.shared-view-all:hover {
  color: var(--primary);
}

.shared-item {
  margin-bottom: var(--space-lg);
}

.shared-item-title {
  font-size: 1.05rem;
  margin-bottom: 0.5rem;
}
.shared-item-title a {
  color: var(--navy);
  text-decoration: none;
  font-weight: 600;
}
.shared-item-title a:hover {
  color: var(--primary);
  text-decoration: underline;
}

.shared-item-body {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.shared-item-thumb {
  width: 80px;
  height: 80px;
  border-radius: var(--radius);
  object-fit: cover;
  flex-shrink: 0;
  border: 1px solid var(--gray-200);
}

.shared-item-body p {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-secondary);
}

.section-header .shared-view-all {
  margin-bottom: 0;
}

@media (max-width: 800px) {
  .shared-grid { grid-template-columns: 1fr; }
}

@media (max-width: 900px) {
  .news-cards-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .news-cards-grid { grid-template-columns: 1fr; }
}

.section-cta {
  margin-top: var(--space-xl);
  text-align: center;
}



/* ---- Responsive ---- */
@media (max-width: 800px) {
  .mission-grid { grid-template-columns: 1fr; }
}

@media (max-width: 600px) {
  .hero { padding: var(--space-2xl) 0 var(--space-xl); }
  .hero-accent { display: none; }
}
</style>

<!-- Floating particle animation (light theme: blue dots on white) -->
<script>
const canvas = document.getElementById('particles') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d');
  let w = 0, h = 0;

  interface Particle {
    x: number; y: number; vx: number; vy: number;
    r: number; a: number; pulse: number; speed: number;
  }

  const particles: Particle[] = [];
  const COUNT = 50;

  function resize() {
    w = canvas.width = canvas.offsetWidth;
    h = canvas.height = canvas.offsetHeight;
  }

  function init() {
    resize();
    for (let i = 0; i < COUNT; i++) {
      const speed = 0.12 + Math.random() * 0.2;
      const angle = Math.random() * Math.PI * 2;
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 1 + Math.random() * 2,
        a: 0.08 + Math.random() * 0.18,
        pulse: Math.random() * Math.PI * 2,
        speed: 0.006 + Math.random() * 0.012,
      });
    }
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, h);

    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.pulse += p.speed;

      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;

      const alpha = p.a * (0.5 + 0.5 * Math.sin(p.pulse));

      // Soft glow
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha * 0.08})`;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  init();
  draw();
  window.addEventListener('resize', resize);
}
</script>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
