---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import research from '../content/research.json';
import news from '../content/news.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid-overlay"></div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="hero-badge">University of Arizona</span>
        <span class="hero-sep">·</span>
        <span class="hero-badge">Medical Imaging AI</span>
      </div>
      <h1 class="hero-title">
        <em>Physics meets AI</em><br>
        in medical imaging.
      </h1>
      <p class="hero-desc">{site.tagline}</p>
      <div class="hero-actions">
        <a href={`${base}research/`} class="btn btn-primary">Explore Research</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-n">4</span>
          <span class="hero-stat-l">Research Areas</span>
        </div>
        <div class="hero-stat-div"></div>
        <div class="hero-stat">
          <span class="hero-stat-n">5+</span>
          <span class="hero-stat-l">Active Projects</span>
        </div>
        <div class="hero-stat-div"></div>
        <div class="hero-stat">
          <span class="hero-stat-n">Open</span>
          <span class="hero-stat-l">Positions Available</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">↓</div>
  </section>

  <!-- ============================================================
       MISSION BRIEF
  ============================================================ -->
  <section class="section">
    <div class="container mission-grid">
      <div class="mission-left">
        <p class="section-label">Our Mission</p>
        <h2>Bridging simulation and AI to advance radiology</h2>
        <div class="divider"></div>
      </div>
      <div class="mission-right">
        <p class="mission-text">{site.mission}</p>
        <a href={`${base}research/`} class="mission-link">Read more about our research →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RESEARCH AREAS
  ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Research</p>
        <h2>What we work on</h2>
      </div>
      <div class="grid-2 research-grid">
        {research.map(r => (
          <a href={`${base}research/`} class="research-card">
            <div class="rc-icon">{r.icon}</div>
            <div class="rc-body">
              <h3>{r.title}</h3>
              <p>{r.short}</p>
              <div class="rc-tags">
                {r.projects.slice(0, 2).map(p => (
                  <span class="tag">{p}</span>
                ))}
              </div>
            </div>
            <span class="rc-arrow">→</span>
          </a>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}research/`} class="btn btn-navy">All Research Areas →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURED PROJECTS
  ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Highlights</p>
        <h2>Flagship projects</h2>
        <p>Selected ongoing research shaping the future of in silico medical imaging evaluation.</p>
      </div>
      <div class="projects-list">
        <div class="project-item">
          <div class="pi-number">01</div>
          <div class="pi-content">
            <h3>Virtual Lung Screening Trial (VLST)</h3>
            <p>An end-to-end virtual clinical trial framework simulating patient anatomy, CT acquisition, and AI-based nodule detection — enabling large-scale, radiation-free protocol evaluation.</p>
            <div class="pi-tags">
              <span class="tag tag--red">CT Simulation</span>
              <span class="tag tag--navy">Digital Phantoms</span>
              <span class="tag">Lung Cancer</span>
            </div>
          </div>
        </div>
        <div class="project-item">
          <div class="pi-number">02</div>
          <div class="pi-content">
            <h3>NodMAISI — Nodule Multi-scale AI</h3>
            <p>A multi-scale foundation model for pulmonary nodule detection and characterization in low-dose and standard-dose CT, achieving robust performance with minimal labeled data.</p>
            <div class="pi-tags">
              <span class="tag tag--red">Foundation Models</span>
              <span class="tag tag--navy">Weakly Supervised</span>
              <span class="tag">Nodule Detection</span>
            </div>
          </div>
        </div>
        <div class="project-item">
          <div class="pi-number">03</div>
          <div class="pi-content">
            <h3>CPU-Index Framework</h3>
            <p>A comprehensive, task-based CT protocol utility index that quantifies image quality in terms of clinically meaningful diagnostic tasks — bridging physics and clinical performance.</p>
            <div class="pi-tags">
              <span class="tag tag--red">Image Quality</span>
              <span class="tag tag--navy">CT Protocol</span>
              <span class="tag">Evaluation</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       NEWS
  ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Lab News</p>
        <h2>Latest updates</h2>
      </div>
      <div class="grid-3">
        {news.map(n => (
          <article class="news-card card">
            <span class="news-category tag tag--red">{n.category}</span>
            <time class="news-date" datetime={n.date}>
              {new Date(n.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
            </time>
            <h4 class="news-title">{n.title}</h4>
            <p class="news-summary">{n.summary}</p>
          </article>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}news/`} class="btn btn-navy">All News →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       JOIN CTA BANNER
  ============================================================ -->
  <section class="join-banner">
    <div class="container join-inner">
      <div class="join-text">
        <p class="section-label" style="color:rgba(255,255,255,0.6)">We're Recruiting</p>
        <h2>Join the Tushar Lab</h2>
        <p>We welcome motivated PhD students, postdocs, and visiting researchers passionate about medical imaging AI and virtual trials.</p>
      </div>
      <div class="join-actions">
        <a href={`${base}opportunities/`} class="btn btn-primary">Open Positions</a>
        <a href={`mailto:${site.email}`} class="btn btn-outline">Email Dr. Tushar</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Hero ---- */
.hero {
  position: relative;
  background: var(--navy);
  min-height: 88vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 70% at 60% 50%, rgba(171,5,32,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 50% 80% at 10% 80%, rgba(26,58,107,0.5) 0%, transparent 60%);
}

.hero-grid-overlay {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding-top: var(--space-2xl);
  padding-bottom: var(--space-2xl);
  max-width: 800px;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: var(--space-md);
}
.hero-badge {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.hero-sep { color: var(--cardinal); }

.hero-title {
  color: var(--white);
  font-size: clamp(2.8rem, 6vw, 4.5rem);
  line-height: 1.1;
  margin-bottom: var(--space-md);
}
.hero-title em {
  font-style: italic;
  color: rgba(255,255,255,0.6);
}

.hero-desc {
  color: rgba(255,255,255,0.65);
  font-size: 1.1rem;
  max-width: 560px;
  margin-bottom: var(--space-lg);
  font-weight: 300;
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-top: var(--space-lg);
  border-top: 1px solid rgba(255,255,255,0.1);
}
.hero-stat { display: flex; flex-direction: column; gap: 2px; }
.hero-stat-n {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
}
.hero-stat-l {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.hero-stat-div {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.15);
}

.hero-scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.25);
  font-size: 1.2rem;
  animation: bounce 2s infinite;
}
@keyframes bounce {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ---- Mission ---- */
.mission-grid {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: var(--space-xl);
  align-items: start;
}
.mission-text {
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
}
.mission-link {
  color: var(--cardinal);
  font-weight: 500;
  font-size: 0.9rem;
  transition: letter-spacing 0.2s;
}
.mission-link:hover { letter-spacing: 0.02em; }

/* ---- Research cards ---- */
.research-card {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  position: relative;
}
.research-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
  border-color: var(--cardinal);
}
.rc-icon {
  font-size: 2rem;
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gray-100);
  border-radius: var(--radius);
}
.rc-body { flex: 1; }
.rc-body h3 { color: var(--navy); margin-bottom: 0.4rem; font-size: 1.1rem; }
.rc-body p { font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem; }
.rc-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.rc-arrow {
  color: var(--cardinal);
  font-size: 1.2rem;
  flex-shrink: 0;
  transition: transform 0.2s;
}
.research-card:hover .rc-arrow { transform: translateX(4px); }

/* ---- Projects list ---- */
.projects-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.project-item {
  display: flex;
  gap: var(--space-lg);
  padding: var(--space-lg);
  border-bottom: 1px solid var(--gray-200);
  transition: background 0.2s;
}
.project-item:last-child { border-bottom: none; }
.project-item:hover { background: var(--sand); }
.pi-number {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--gray-200);
  line-height: 1;
  flex-shrink: 0;
  width: 52px;
}
.pi-content h3 { margin-bottom: 0.4rem; }
.pi-content p { font-size: 0.95rem; margin-bottom: 0.75rem; }
.pi-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

/* ---- News ---- */
.news-card { display: flex; flex-direction: column; gap: 0.5rem; }
.news-date {
  display: block;
  font-size: 0.78rem;
  color: var(--gray-400);
  margin-top: 0.25rem;
}
.news-title { font-size: 1rem; color: var(--navy); }
.news-summary { font-size: 0.875rem; line-height: 1.6; }

/* ---- CTA ---- */
.section-cta {
  margin-top: var(--space-xl);
  text-align: center;
}

/* ---- Join banner ---- */
.join-banner {
  background: var(--navy);
  padding: var(--space-2xl) 0;
  position: relative;
  overflow: hidden;
}
.join-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -45deg,
    rgba(171,5,32,0.05) 0px,
    rgba(171,5,32,0.05) 1px,
    transparent 1px,
    transparent 32px
  );
}
.join-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-xl);
  position: relative;
  z-index: 1;
}
.join-text h2 { color: var(--white); }
.join-text p { color: rgba(255,255,255,0.65); max-width: 480px; margin-top: 0.5rem; }
.join-actions { display: flex; gap: var(--space-sm); flex-shrink: 0; flex-wrap: wrap; }

@media (max-width: 800px) {
  .mission-grid { grid-template-columns: 1fr; }
  .join-inner { flex-direction: column; align-items: flex-start; }
}
</style>
