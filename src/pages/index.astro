---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout>

  <!-- ============================================================
       HERO — Dark, particles, massive typography
  ============================================================ -->
  <section class="hero">
    <canvas id="particles" class="hero-canvas"></canvas>
    <div class="grid-pattern"></div>
    <div class="hero-glow"></div>
    <div class="container hero-content">
      <div class="hero-badge reveal">University of Arizona</div>
      <h1 class="hero-title reveal" style="transition-delay:0.1s">
        Data-centric AI for<br /><em>healthcare</em> and <em>medicine.</em>
      </h1>
      <p class="hero-desc reveal" style="transition-delay:0.2s">
        The Tushar Lab is a newly established research group at the University of Arizona
        advancing data-centric AI for healthcare and medicine through data discovery,
        intelligent tools, and the integration of clinical, simulated, and synthetic datasets.
      </p>
      <p class="hero-affiliation reveal" style="transition-delay:0.25s">
        Department of Radiology and Imaging Sciences &middot; University of Arizona
      </p>
      <div class="hero-actions reveal" style="transition-delay:0.3s">
        <a href={`${base}research/`} class="btn btn-primary">Explore Research &rarr;</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       ABOUT — Slightly lighter dark bg, pull-quote style
  ============================================================ -->
  <section class="section section--alt about-section">
    <div class="grid-pattern"></div>
    <div class="container">
      <div class="about-grid">
        <div class="about-left reveal">
          <p class="section-label">About the Lab</p>
          <h2>A new lab with a clear research vision</h2>
        </div>
        <div class="about-right">
          <blockquote class="about-quote reveal" style="transition-delay:0.1s">
            How do we develop AI for healthcare and medicine that is trustworthy,
            rigorously evaluated, and grounded in clinical needs?
          </blockquote>
          <p class="about-text reveal" style="transition-delay:0.15s">
            Our work combines data-centric AI, intelligent tools, and clinical, simulated,
            and synthetic data to move from data to discovery in ways that better support
            healthcare professionals, reduce workload, and strengthen reliability in practice.
          </p>
          <p class="about-text reveal" style="transition-delay:0.2s">
            As a newly established and growing lab, we welcome collaboration with researchers,
            students, and partners who share an interest in trustworthy, reproducible, and
            clinically grounded AI.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RESEARCH PILLARS — Three glassy cards
  ============================================================ -->
  <section class="section pillars-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Research Pillars</p>
        <h2>Three directions, one mission</h2>
      </div>
      <div class="grid-3 pillars-grid">

        <div class="pillar-card card reveal" style="transition-delay:0.1s">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/>
            </svg>
          </div>
          <h3>Data Discovery</h3>
          <p>Developing methods for curating, auditing, and discovering high-quality datasets that power reliable medical AI systems.</p>
        </div>

        <div class="pillar-card card reveal" style="transition-delay:0.2s">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/>
              <line x1="9" y1="22" x2="15" y2="22"/>
            </svg>
          </div>
          <h3>Intelligent Tools</h3>
          <p>Building foundation models and AI-driven tools for medical image analysis, segmentation, and clinical decision support.</p>
        </div>

        <div class="pillar-card card reveal" style="transition-delay:0.3s">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 2 7 12 12 22 7 12 2"/>
              <polyline points="2 17 12 22 22 17"/>
              <polyline points="2 12 12 17 22 12"/>
            </svg>
          </div>
          <h3>Data Integration</h3>
          <p>Bridging clinical, simulated, and synthetic data to create robust evaluation frameworks and training pipelines for medical AI.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       OPPORTUNITIES — General welcoming message
  ============================================================ -->
  <section class="section section--alt opportunities-section">
    <div class="grid-pattern"></div>
    <div class="container">
      <div class="opp-grid">
        <div class="opp-left reveal">
          <p class="section-label">Opportunities</p>
          <h2>Join Us</h2>
        </div>
        <div class="opp-right reveal" style="transition-delay:0.1s">
          <div class="opp-card">
            <p>
              The Tushar Lab is a newly established and growing research group. While specific
              positions have not yet been finalized, we anticipate openings for PhD students,
              postdoctoral researchers, and research staff in the near future.
            </p>
            <p>
              We are always eager to hear from motivated individuals with interests in medical
              imaging AI, data-centric machine learning, and computational health sciences. If
              our research resonates with you, we encourage you to check back here for updates
              or reach out directly.
            </p>
            <p class="opp-note">
              Opportunities will be posted here as they become available.
            </p>
            <a href={`${base}contact/`} class="btn btn-ghost">Get in Touch &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Hero ---- */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: var(--bg-deep);
  overflow: hidden;
  padding-top: var(--nav-h);
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-glow {
  position: absolute;
  top: 20%;
  left: 50%;
  width: 600px;
  height: 600px;
  transform: translate(-50%, -30%);
  background: radial-gradient(circle, rgba(171,5,32,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: var(--space-3xl) 0;
  max-width: 760px;
}

.hero-badge {
  display: inline-block;
  padding: 0.4rem 1rem;
  border-radius: var(--radius-pill);
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.03);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-lg);
}

.hero-title {
  font-size: clamp(2.8rem, 6.5vw, 4.8rem);
  line-height: 1.08;
  color: var(--white);
  margin-bottom: var(--space-md);
  letter-spacing: -0.02em;
}

.hero-title em {
  font-style: italic;
  color: var(--cardinal);
  text-shadow: 0 0 40px var(--cardinal-glow), 0 0 80px rgba(171,5,32,0.15);
}

.hero-desc {
  color: var(--text-muted);
  font-size: 1.1rem;
  line-height: 1.75;
  max-width: 600px;
  margin-bottom: var(--space-sm);
  font-weight: 300;
}

.hero-affiliation {
  font-size: 0.8rem;
  color: var(--text-dim);
  margin-bottom: var(--space-lg);
  font-weight: 400;
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- About ---- */
.about-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-xl);
  align-items: start;
}

.about-quote {
  font-family: var(--font-display);
  font-size: 1.35rem;
  line-height: 1.5;
  color: var(--text);
  margin-bottom: var(--space-lg);
  padding-left: var(--space-md);
  border-left: 2px solid var(--cardinal);
  font-style: italic;
}

.about-text {
  font-size: 1rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
  color: var(--text-muted);
}

/* ---- Research Pillars ---- */
.pillar-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.pillar-icon {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius);
  background: rgba(171,5,32,0.08);
  color: var(--cardinal);
  margin-bottom: var(--space-xs);
}

.pillar-card h3 {
  font-size: 1.2rem;
  margin-bottom: 0.25rem;
}

.pillar-card p {
  font-size: 0.92rem;
  line-height: 1.7;
}

/* ---- Opportunities ---- */
.opp-grid {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: var(--space-xl);
  align-items: start;
}

.opp-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--cardinal);
  border-radius: var(--radius-lg);
  padding: var(--space-lg) var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  box-shadow: 0 0 30px rgba(171,5,32,0.05);
}

.opp-card p {
  font-size: 0.95rem;
  line-height: 1.8;
}

.opp-note {
  font-size: 0.85rem !important;
  color: var(--text-dim) !important;
  font-style: italic;
}

.opp-card .btn {
  align-self: flex-start;
  margin-top: var(--space-xs);
}

/* ---- Responsive ---- */
@media (max-width: 800px) {
  .about-grid { grid-template-columns: 1fr; }
  .opp-grid { grid-template-columns: 1fr; }
  .opp-card { padding: var(--space-lg); }
}

@media (max-width: 600px) {
  .hero { min-height: auto; padding-top: calc(var(--nav-h) + var(--space-xl)); padding-bottom: var(--space-xl); }
  .hero-content { padding: var(--space-xl) 0; }
  .hero-glow { width: 300px; height: 300px; }
}
</style>

<!-- Particle animation -->
<script>
const canvas = document.getElementById('particles') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d');
  let w = 0, h = 0;

  interface Particle {
    x: number; y: number; vx: number; vy: number;
    r: number; a: number; pulse: number; speed: number;
  }

  const particles: Particle[] = [];
  const COUNT = 60;

  function resize() {
    w = canvas.width = canvas.offsetWidth;
    h = canvas.height = canvas.offsetHeight;
  }

  function init() {
    resize();
    for (let i = 0; i < COUNT; i++) {
      const speed = 0.15 + Math.random() * 0.25;
      const angle = Math.random() * Math.PI * 2;
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 1 + Math.random() * 1.5,
        a: 0.15 + Math.random() * 0.35,
        pulse: Math.random() * Math.PI * 2,
        speed: 0.008 + Math.random() * 0.015,
      });
    }
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, h);

    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.pulse += p.speed;

      // Wrap around
      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;

      const alpha = p.a * (0.6 + 0.4 * Math.sin(p.pulse));
      const glow = p.r * 3;

      // Outer glow
      ctx.beginPath();
      ctx.arc(p.x, p.y, glow, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(171, 5, 32, ${alpha * 0.15})`;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200, 180, 180, ${alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  init();
  draw();
  window.addEventListener('resize', resize);
}
</script>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
