---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import news from '../content/news.json';
import resources from '../content/resources.json';
const base = import.meta.env.BASE_URL;
const recentSoftware = resources.filter(r => r.type === 'Software').slice(0, 2);
const recentData = resources.filter(r => r.type === 'Dataset' || r.type === 'Model').slice(0, 2);

function assetUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
function itemLink(item: { link?: string; github?: string }) {
  return item.link || item.github || `${base}resources/`;
}
---

<BaseLayout>

  <!-- ============================================================
       HERO — Clean, academic, honest about being new
  ============================================================ -->
  <section class="hero">
    <canvas id="particles" class="hero-canvas"></canvas>
    <div class="container hero-content">
      <h1 class="hero-title reveal">
        Data-centric AI for Healthcare and Medicine
      </h1>
      <p class="hero-desc reveal" style="transition-delay:0.1s">
        The Tushar Lab is a newly established research group at the University of Arizona
        advancing data-centric AI for healthcare and medicine through data discovery,
        intelligent tools, and the integration of clinical, simulated, and synthetic datasets.
      </p>
      <p class="hero-dept reveal" style="transition-delay:0.15s">
        Department of Radiology and Imaging Sciences &middot; University of Arizona
      </p>
      <div class="hero-actions reveal" style="transition-delay:0.2s">
        <a href={`${base}research/`} class="btn btn-primary">Our Research</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ============================================================
       AFFILIATION LOGOS — Lab & Department
  ============================================================ -->
  <section class="affiliation-strip">
    <div class="container affiliation-inner reveal">
      <div class="affiliation-logo-link">
        <img src={`${base}images/TusharLAB_logo.svg`} alt="Tushar Lab" class="affiliation-logo affiliation-logo--lab" />
      </div>
      <span class="affiliation-divider" aria-hidden="true"></span>
      <a href="https://radiology.arizona.edu/" target="_blank" rel="noopener" class="affiliation-logo-link" aria-label="Department of Radiology and Imaging Sciences, University of Arizona">
        <img src={`${base}images/radiology-and-imaging-sciences_web_header.png`} alt="" class="affiliation-logo affiliation-logo--dept" />
      </a>
    </div>
  </section>

  <!-- ============================================================
       MISSION & RESEARCH — Combined section
  ============================================================ -->
  <section class="section mission-section">
    <div class="container mission-grid">
      <div class="mission-left reveal">
        <p class="section-label">About the Lab</p>
        <h2>Our Mission</h2>
      </div>
      <div class="mission-right reveal" style="transition-delay:0.1s">
        <p class="mission-text">
          We are building a research program around a central question:
          <em>how do we develop AI for healthcare and medicine that is trustworthy,
          rigorously evaluated, and grounded in clinical needs?</em>
        </p>
        <p class="mission-text">
          Our work combines data-centric AI, intelligent tools, and clinical, simulated,
          and synthetic data to move from data to discovery in ways that better support
          healthcare professionals, reduce workload, and strengthen reliability in practice.
        </p>
        <p class="mission-text">
          As a newly established and growing lab, we welcome collaboration with researchers,
          students, and partners who share an interest in trustworthy, reproducible,
          and clinically grounded AI.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RECENTLY SHARED — Software & Data
  ============================================================ -->
  <section class="section recently-shared-section">
    <div class="container">
      <div class="shared-grid reveal">
        <!-- Recently Shared Software -->
        <div class="shared-column">
          <h2 class="shared-heading">Recently Shared Software</h2>
          <a href={`${base}resources/`} class="shared-view-all">✦ View All Software</a>
          {recentSoftware.map(item => (
            <div class="shared-item">
              <h3 class="shared-item-title">
                <a href={itemLink(item)}>{item.title}</a>
              </h3>
              <div class="shared-item-body">
                {item.image && (
                  <img src={assetUrl(item.image)} alt={item.title} class="shared-item-thumb" />
                )}
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Recently Shared Data -->
        <div class="shared-column">
          <h2 class="shared-heading">Recently Shared Data</h2>
          <a href={`${base}resources/`} class="shared-view-all">✦ View All Data</a>
          {recentData.map(item => (
            <div class="shared-item">
              <h3 class="shared-item-title">
                <a href={itemLink(item)}>{item.title}</a>
              </h3>
              <div class="shared-item-body">
                {item.image && (
                  <img src={assetUrl(item.image)} alt={item.title} class="shared-item-thumb" />
                )}
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       NEWS — Latest updates
  ============================================================ -->
  <section class="section news-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>News</h2>
        <a href={`${base}news/`} class="shared-view-all">✦ View All News</a>
      </div>
      <div class="news-cards-grid">
        {news.slice(0, 3).map(n => (
          <a href={`${base}news/${n.id}/`} class="news-card-v2 reveal">
            {n.image && (
              <div class="news-card-image">
                <img src={assetUrl(n.image)} alt={n.title} />
              </div>
            )}
            <div class="news-card-body">
              <h4 class="news-card-title">{n.title}</h4>
              <p class="news-card-summary">{n.summary}</p>
              <span class="news-card-read-more">✦ Read More</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---- Hero ---- */
.hero {
  position: relative;
  padding: var(--space-3xl) 0 var(--space-2xl);
  background: linear-gradient(180deg, #F8FAFF 0%, var(--white) 100%);
  overflow: hidden;
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-accent {
  position: absolute;
  top: 0;
  right: 0;
  width: 45%;
  height: 100%;
  background: radial-gradient(ellipse at 70% 40%, rgba(12, 35, 75, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 720px;
}

.hero-title {
  color: var(--gray-900);
  font-size: clamp(2.8rem, 6.5vw, 4.2rem);
  line-height: 1.1;
  margin-bottom: var(--space-md);
  letter-spacing: -0.03em;
}

.hero-desc {
  color: var(--text-secondary);
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 620px;
  margin-bottom: var(--space-md);
  font-weight: 400;
}

.hero-dept {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--gray-400);
  margin-bottom: var(--space-lg);
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Affiliation strip ---- */
.affiliation-strip {
  background: var(--bg-warm);
  border-top: 1px solid var(--gray-100);
  border-bottom: 1px solid var(--gray-100);
  padding: var(--space-lg) 0;
}

.affiliation-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xl);
  flex-wrap: wrap;
}

.affiliation-logo-link {
  display: inline-flex;
  align-items: center;
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.affiliation-logo-link:hover {
  opacity: 0.8;
  transform: scale(1.03);
}

.affiliation-logo--lab {
  height: 126px;
  width: auto;
}

.affiliation-logo--dept {
  height: 52px;
  width: auto;
}

.affiliation-divider {
  width: 1px;
  height: 48px;
  background: var(--gray-300);
  flex-shrink: 0;
}

@media (max-width: 600px) {
  .affiliation-inner {
    flex-direction: column;
    gap: var(--space-md);
  }
  .affiliation-divider {
    width: 48px;
    height: 1px;
  }
  .affiliation-logo--lab {
    height: 102px;
  }
  .affiliation-logo--dept {
    height: 40px;
  }
}

/* ---- Mission ---- */
.mission-section {
  border-top: 1px solid var(--gray-100);
}

.mission-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-xl);
  align-items: start;
}
.mission-text {
  font-size: 1.02rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}
.mission-text em {
  font-style: italic;
  color: var(--gray-800);
  font-weight: 500;
}

/* ---- News ---- */
.news-cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}

.news-card-v2 {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  border: 1px solid var(--gray-200);
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.news-card-v2:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.news-card-image {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--gray-100);
}
.news-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.news-card-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.news-card-title {
  font-size: 1rem;
  color: var(--navy);
  line-height: 1.4;
}

.news-card-summary {
  font-size: 0.875rem;
  line-height: 1.65;
  flex: 1;
}

.news-card-read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--navy);
  margin-top: var(--space-sm);
}
.news-card-v2:hover .news-card-read-more {
  color: var(--primary);
}

/* ---- Recently Shared ---- */
.recently-shared-section {
  border-top: 1px solid var(--gray-200);
  border-bottom: 1px solid var(--gray-200);
  background: var(--white);
}

.shared-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
}

.shared-heading {
  font-size: clamp(1.3rem, 2.5vw, 1.6rem);
  color: var(--gray-900);
  margin-bottom: 0.5rem;
}

.shared-view-all {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--navy);
  text-decoration: none;
  margin-bottom: var(--space-lg);
}
.shared-view-all:hover {
  color: var(--primary);
}

.shared-item {
  margin-bottom: var(--space-lg);
}

.shared-item-title {
  font-size: 1.05rem;
  margin-bottom: 0.5rem;
}
.shared-item-title a {
  color: var(--navy);
  text-decoration: none;
  font-weight: 600;
}
.shared-item-title a:hover {
  color: var(--primary);
  text-decoration: underline;
}

.shared-item-body {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.shared-item-thumb {
  width: 80px;
  height: 80px;
  border-radius: var(--radius);
  object-fit: cover;
  flex-shrink: 0;
  border: 1px solid var(--gray-200);
}

.shared-item-body p {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-secondary);
}

.section-header .shared-view-all {
  margin-bottom: 0;
}

@media (max-width: 800px) {
  .shared-grid { grid-template-columns: 1fr; }
}

@media (max-width: 900px) {
  .news-cards-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .news-cards-grid { grid-template-columns: 1fr; }
}

.section-cta {
  margin-top: var(--space-xl);
  text-align: center;
}



/* ---- Responsive ---- */
@media (max-width: 800px) {
  .mission-grid { grid-template-columns: 1fr; }
}

@media (max-width: 600px) {
  .hero { padding: var(--space-2xl) 0 var(--space-xl); }
  .hero-accent { display: none; }
}
</style>

<!-- Floating particle animation (light theme: blue dots on white) -->
<script>
const canvas = document.getElementById('particles') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d');
  let w = 0, h = 0;

  interface Particle {
    x: number; y: number; vx: number; vy: number;
    r: number; a: number; pulse: number; speed: number;
  }

  const particles: Particle[] = [];
  const COUNT = 50;

  function resize() {
    w = canvas.width = canvas.offsetWidth;
    h = canvas.height = canvas.offsetHeight;
  }

  function init() {
    resize();
    for (let i = 0; i < COUNT; i++) {
      const speed = 0.12 + Math.random() * 0.2;
      const angle = Math.random() * Math.PI * 2;
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 1 + Math.random() * 2,
        a: 0.08 + Math.random() * 0.18,
        pulse: Math.random() * Math.PI * 2,
        speed: 0.006 + Math.random() * 0.012,
      });
    }
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, h);

    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.pulse += p.speed;

      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;

      const alpha = p.a * (0.5 + 0.5 * Math.sin(p.pulse));

      // Soft glow
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha * 0.08})`;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  init();
  draw();
  window.addEventListener('resize', resize);
}
</script>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
