---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import research from '../content/research.json';
import team from '../content/team.json';
import news from '../content/news.json';
const base = import.meta.env.BASE_URL;
const pi = team.find(m => m.role === 'Principal Investigator');
---

<BaseLayout>

  <!-- ============================================================
       HERO — Clean, academic, honest about being new
  ============================================================ -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-pillars">
        <span class="hero-pill">Medical Imaging AI</span>
        <span class="hero-pill-sep">&middot;</span>
        <span class="hero-pill">Virtual Imaging Trials</span>
        <span class="hero-pill-sep">&middot;</span>
        <span class="hero-pill">Data-Centric AI</span>
      </div>
      <h1 class="hero-title">
        Building rigorous AI<br />for medical imaging.
      </h1>
      <p class="hero-desc">
        The Tushar Lab is a newly established research group at the University of Arizona,
        focused on trustworthy AI for radiology through simulation, synthetic data,
        and clinically grounded evaluation.
      </p>
      <div class="hero-actions">
        <a href={`${base}research/`} class="btn btn-primary">Our Research</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ============================================================
       MISSION — Short, credible, forward-looking
  ============================================================ -->
  <section class="section mission-section">
    <div class="container mission-grid">
      <div class="mission-left">
        <p class="section-label">About the Lab</p>
        <h2>A new lab with a clear direction</h2>
      </div>
      <div class="mission-right">
        <p class="mission-text">
          We are building a research program around a core question:
          <em>How do we develop medical imaging AI that is truly reliable?</em>
        </p>
        <p class="mission-text">
          Our approach combines virtual imaging trials&mdash;physics-based simulations of the entire imaging
          pipeline&mdash;with data-centric methods that focus on improving the quality, diversity, and
          representativeness of training data. We aim to make AI evaluation more rigorous and AI development
          more grounded in clinical reality.
        </p>
        <p class="mission-text">
          The lab is newly established and currently growing. We are open to collaboration with researchers
          who share an interest in reproducible, clinically relevant AI.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RESEARCH THEMES — Clean cards, no inflation
  ============================================================ -->
  <section class="section section--alt research-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Research</p>
        <h2>What we work on</h2>
        <p>Our research directions span AI development, simulation, and evaluation for medical imaging.</p>
      </div>
      <div class="grid-2 research-grid">
        {research.map(r => (
          <a href={`${base}research/`} class="research-card">
            <div class="rc-icon-wrap">
              <svg class="rc-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {r.icon === 'brain' && <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z M9 22h6"/>}
                {r.icon === 'monitor' && <><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></>}
                {r.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                {r.icon === 'layers' && <><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></>}
              </svg>
            </div>
            <div class="rc-body">
              <h3>{r.title}</h3>
              <p>{r.short}</p>
            </div>
            <span class="rc-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       SELECTED DIRECTIONS — Representative work, not "flagship"
  ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Selected Work</p>
        <h2>Representative research directions</h2>
        <p>Projects that reflect the lab's emerging research program and the PI's prior work.</p>
      </div>
      <div class="directions-list">

        <div class="direction-item">
          <div class="di-marker"></div>
          <div class="di-content">
            <h3>Virtual Lung Screening Trial (VLST)</h3>
            <p>An end-to-end simulation framework for lung cancer screening&mdash;modeling patient anatomy, CT acquisition, and AI-based detection&mdash;enabling protocol evaluation without patient exposure.</p>
            <div class="di-tags">
              <span class="tag tag--red">CT Simulation</span>
              <span class="tag tag--navy">Digital Phantoms</span>
              <span class="tag">Lung Cancer</span>
            </div>
          </div>
        </div>

        <div class="direction-item">
          <div class="di-marker"></div>
          <div class="di-content">
            <h3>NodMAISI</h3>
            <p>A multi-scale AI model for pulmonary nodule detection and characterization, designed to achieve strong performance with limited labeled data through weakly-supervised and self-supervised strategies.</p>
            <div class="di-tags">
              <span class="tag tag--red">Deep Learning</span>
              <span class="tag tag--navy">Weakly Supervised</span>
              <span class="tag">Nodule Detection</span>
            </div>
          </div>
        </div>

        <div class="direction-item">
          <div class="di-marker"></div>
          <div class="di-content">
            <h3>SYN-LUNGS</h3>
            <p>A synthetic lung CT generation pipeline that produces anatomically realistic images with controllable pathology, supporting both AI training and privacy-preserving data sharing.</p>
            <div class="di-tags">
              <span class="tag tag--red">Generative AI</span>
              <span class="tag tag--navy">Synthetic Data</span>
              <span class="tag">Open Science</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       PI SECTION — Brief, professional, connecting background to vision
  ============================================================ -->
  <section class="section section--alt pi-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Principal Investigator</p>
      </div>
      <div class="pi-card">
        <div class="pi-avatar-wrap">
          {pi?.photo
            ? <img src={pi.photo} alt={pi?.name} class="pi-avatar-img" />
            : <div class="pi-avatar-placeholder">
                <span>{pi?.name.split(' ').map((n: string) => n[0]).join('')}</span>
              </div>
          }
        </div>
        <div class="pi-info">
          <h3>{pi?.name}</h3>
          <p class="pi-title">{pi?.title}</p>
          <p class="pi-affil">{pi?.affiliation}</p>
          <div class="divider"></div>
          <p class="pi-bio">{pi?.bio}</p>
          <div class="pi-links">
            {pi?.email && <a href={`mailto:${pi.email}`} class="pi-link">{pi.email}</a>}
            {pi?.github && <a href={pi.github} class="pi-link" target="_blank" rel="noopener">GitHub</a>}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       NEWS — Latest updates
  ============================================================ -->
  <section class="section news-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">News</p>
        <h2>Recent updates</h2>
      </div>
      <div class="grid-3">
        {news.slice(0, 3).map(n => (
          <article class="news-card card">
            <time class="news-date" datetime={n.date}>
              {new Date(n.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
            </time>
            <h4 class="news-title">{n.title}</h4>
            <p class="news-summary">{n.summary}</p>
          </article>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}news/`} class="btn btn-outline">All News &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       JOIN — Welcoming, academic, appropriate for a new lab
  ============================================================ -->
  <section class="join-section">
    <div class="container join-inner">
      <div class="join-content">
        <p class="section-label" style="color:rgba(255,255,255,0.5)">Opportunities</p>
        <h2>We are building the team</h2>
        <p>
          The Tushar Lab is actively recruiting PhD students, postdoctoral researchers,
          and motivated undergraduates. We welcome applicants with backgrounds in medical imaging,
          machine learning, computational physics, or related fields.
        </p>
        <div class="join-actions">
          <a href={`${base}opportunities/`} class="btn btn-primary">Open Positions</a>
          <a href={`mailto:${site.email}`} class="btn btn-outline-white">Contact Dr. Tushar</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Hero ---- */
.hero {
  position: relative;
  padding: var(--space-3xl) 0 var(--space-2xl);
  background: var(--white);
  overflow: hidden;
}

.hero-accent {
  position: absolute;
  top: 0;
  right: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(135deg, transparent 0%, var(--cardinal-light) 100%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 680px;
}

.hero-pillars {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: var(--space-md);
  flex-wrap: wrap;
}
.hero-pill {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cardinal);
}
.hero-pill-sep {
  color: var(--gray-300);
  font-size: 0.8rem;
}

.hero-title {
  color: var(--gray-900);
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  line-height: 1.15;
  margin-bottom: var(--space-md);
  letter-spacing: -0.025em;
}

.hero-desc {
  color: var(--text-secondary);
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: var(--space-lg);
  font-weight: 400;
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Mission ---- */
.mission-section {
  border-top: 1px solid var(--gray-100);
}

.mission-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-xl);
  align-items: start;
}
.mission-text {
  font-size: 1.02rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}
.mission-text em {
  font-style: italic;
  color: var(--gray-800);
  font-weight: 500;
}

/* ---- Research cards ---- */
.research-card {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
  position: relative;
}
.research-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--gray-300);
}
.rc-icon-wrap {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--cardinal-light);
  border-radius: var(--radius);
  flex-shrink: 0;
  color: var(--cardinal);
}
.rc-body { flex: 1; }
.rc-body h3 {
  color: var(--gray-900);
  margin-bottom: 0.4rem;
  font-size: 1.05rem;
}
.rc-body p {
  font-size: 0.9rem;
  line-height: 1.65;
}
.rc-arrow {
  color: var(--gray-300);
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: color 0.2s, transform 0.2s;
}
.research-card:hover .rc-arrow {
  color: var(--cardinal);
  transform: translateX(3px);
}

/* ---- Selected directions ---- */
.directions-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.direction-item {
  display: flex;
  gap: var(--space-lg);
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--gray-100);
  align-items: flex-start;
}
.direction-item:first-child { padding-top: 0; }
.direction-item:last-child { border-bottom: none; }

.di-marker {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--cardinal);
  flex-shrink: 0;
  margin-top: 0.55rem;
}

.di-content h3 {
  margin-bottom: 0.35rem;
  font-size: 1.1rem;
}
.di-content p {
  font-size: 0.95rem;
  line-height: 1.7;
  margin-bottom: 0.75rem;
}
.di-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

/* ---- PI section ---- */
.pi-card {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: var(--space-xl);
  align-items: start;
}

.pi-avatar-wrap {
  aspect-ratio: 1;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 2px solid var(--gray-200);
}
.pi-avatar-img { width: 100%; height: 100%; object-fit: cover; }
.pi-avatar-placeholder {
  width: 100%;
  height: 100%;
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--navy);
  font-family: var(--font-display);
  font-size: 3.5rem;
  font-weight: 700;
  color: rgba(255,255,255,0.2);
}

.pi-info h3 { margin-bottom: 0.2rem; font-size: 1.4rem; }
.pi-title { font-weight: 500; color: var(--gray-700); font-size: 0.95rem; }
.pi-affil { font-size: 0.85rem; color: var(--gray-400); margin-top: 2px; }
.pi-bio {
  font-size: 0.95rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
.pi-links { display: flex; flex-wrap: wrap; gap: var(--space-md); }
.pi-link {
  font-size: 0.85rem;
  color: var(--cardinal);
  font-weight: 500;
  transition: opacity 0.15s;
}
.pi-link:hover { opacity: 0.7; }

/* ---- News ---- */
.news-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.news-date {
  display: block;
  font-size: 0.75rem;
  color: var(--gray-400);
  font-weight: 500;
}
.news-title { font-size: 1rem; color: var(--gray-900); }
.news-summary { font-size: 0.875rem; line-height: 1.65; }

.section-cta {
  margin-top: var(--space-xl);
  text-align: center;
}

/* ---- Join section ---- */
.join-section {
  background: var(--navy);
  padding: var(--space-2xl) 0;
}
.join-inner {
  max-width: 640px;
}
.join-content h2 {
  color: var(--white);
  margin-bottom: var(--space-sm);
}
.join-content p {
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: var(--space-lg);
}
.join-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Responsive ---- */
@media (max-width: 800px) {
  .mission-grid { grid-template-columns: 1fr; }
  .pi-card { grid-template-columns: 1fr; }
  .pi-avatar-wrap { max-width: 160px; }
}

@media (max-width: 600px) {
  .hero { padding: var(--space-2xl) 0 var(--space-xl); }
  .hero-accent { display: none; }
  .direction-item { gap: var(--space-sm); }
}
</style>
