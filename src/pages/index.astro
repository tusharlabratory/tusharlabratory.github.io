---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import research from '../content/research.json';
import news from '../content/news.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout>

  <!-- ============================================================
       HERO — Clean, academic, honest about being new
  ============================================================ -->
  <section class="hero">
    <canvas id="particles" class="hero-canvas"></canvas>
    <div class="container hero-content">
      <div class="hero-pillars reveal">
        <span class="hero-pill">Medical Imaging AI</span>
        <span class="hero-pill-sep">&middot;</span>
        <span class="hero-pill">Virtual Imaging Trials</span>
        <span class="hero-pill-sep">&middot;</span>
        <span class="hero-pill">Data-Centric AI</span>
      </div>
      <h1 class="hero-title reveal" style="transition-delay:0.1s">
        Building rigorous AI<br />for medical imaging.
      </h1>
      <p class="hero-desc reveal" style="transition-delay:0.2s">
        The Tushar Lab is a newly established research group at the University of Arizona,
        focused on trustworthy AI for radiology through simulation, synthetic data,
        and clinically grounded evaluation.
      </p>
      <div class="hero-actions reveal" style="transition-delay:0.3s">
        <a href={`${base}research/`} class="btn btn-primary">Our Research</a>
        <a href={`${base}opportunities/`} class="btn btn-outline">Join the Lab</a>
      </div>
    </div>
    <div class="hero-accent" aria-hidden="true"></div>
  </section>

  <!-- ============================================================
       MISSION — Short, credible, forward-looking
  ============================================================ -->
  <section class="section mission-section">
    <div class="container mission-grid">
      <div class="mission-left reveal">
        <p class="section-label">About the Lab</p>
        <h2>A new lab with a clear direction</h2>
      </div>
      <div class="mission-right reveal" style="transition-delay:0.1s">
        <p class="mission-text">
          We are building a research program around a core question:
          <em>How do we develop medical imaging AI that is truly reliable?</em>
        </p>
        <p class="mission-text">
          Our approach combines virtual imaging trials&mdash;physics-based simulations of the entire imaging
          pipeline&mdash;with data-centric methods that focus on improving the quality, diversity, and
          representativeness of training data. We aim to make AI evaluation more rigorous and AI development
          more grounded in clinical reality.
        </p>
        <p class="mission-text">
          The lab is newly established and currently growing. We are open to collaboration with researchers
          who share an interest in reproducible, clinically relevant AI.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RESEARCH THEMES — Clean cards, no inflation
  ============================================================ -->
  <section class="section section--alt research-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Research</p>
        <h2>Research</h2>
        <p>Our research spans data-centric AI, simulation, and evaluation to make healthcare AI more trustworthy, useful, and clinically grounded.</p>
      </div>
      <div class="grid-4 research-grid">
        {research.map(r => (
          <a href={`${base}research/`} class="research-card">
            <div class="rc-icon-wrap">
              <svg class="rc-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {r.icon === 'brain' && <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z M9 22h6"/>}
                {r.icon === 'monitor' && <><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></>}
                {r.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                {r.icon === 'layers' && <><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></>}
              </svg>
            </div>
            <div class="rc-body">
              <h3>{r.title}</h3>
              <p>{r.short}</p>
            </div>
            <span class="rc-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       NEWS — Latest updates
  ============================================================ -->
  <section class="section news-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">News</p>
        <h2>Recent updates</h2>
      </div>
      <div class="grid-3">
        {news.slice(0, 3).map(n => (
          <article class="news-card card">
            <time class="news-date" datetime={n.date}>
              {new Date(n.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
            </time>
            <h4 class="news-title">{n.title}</h4>
            <p class="news-summary">{n.summary}</p>
          </article>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}news/`} class="btn btn-outline">All News &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       JOIN — Welcoming, academic, appropriate for a new lab
  ============================================================ -->
  <section class="join-section">
    <div class="container join-inner">
      <div class="join-content reveal">
        <p class="section-label" style="color:rgba(255,255,255,0.5)">Opportunities</p>
        <h2>We are building the team</h2>
        <p>
          The Tushar Lab is actively recruiting PhD students, postdoctoral researchers,
          and motivated undergraduates. We welcome applicants with backgrounds in medical imaging,
          machine learning, computational physics, or related fields.
        </p>
        <div class="join-actions">
          <a href={`${base}opportunities/`} class="btn btn-primary">Open Positions</a>
          <a href={`mailto:${site.email}`} class="btn btn-outline-white">Contact Dr. Tushar</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---- Hero ---- */
.hero {
  position: relative;
  padding: var(--space-3xl) 0 var(--space-2xl);
  background: linear-gradient(180deg, #F8FAFF 0%, var(--white) 100%);
  overflow: hidden;
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-accent {
  position: absolute;
  top: 0;
  right: 0;
  width: 45%;
  height: 100%;
  background: radial-gradient(ellipse at 70% 40%, rgba(12, 35, 75, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 680px;
}

.hero-pillars {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: var(--space-md);
  flex-wrap: wrap;
}
.hero-pill {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--primary);
}
.hero-pill-sep {
  color: var(--gray-300);
  font-size: 0.8rem;
}

.hero-title {
  color: var(--gray-900);
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  line-height: 1.15;
  margin-bottom: var(--space-md);
  letter-spacing: -0.025em;
}

.hero-desc {
  color: var(--text-secondary);
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: var(--space-lg);
  font-weight: 400;
}

.hero-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Mission ---- */
.mission-section {
  border-top: 1px solid var(--gray-100);
}

.mission-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-xl);
  align-items: start;
}
.mission-text {
  font-size: 1.02rem;
  line-height: 1.8;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}
.mission-text em {
  font-style: italic;
  color: var(--gray-800);
  font-weight: 500;
}

/* ---- Research cards ---- */
.research-card {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, transform 0.3s ease;
  position: relative;
}
.research-card:hover {
  box-shadow: var(--shadow-md);
  border-color: rgba(171, 5, 32, 0.2);
  transform: translateY(-2px);
}
.rc-icon-wrap {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius);
  flex-shrink: 0;
  color: var(--primary);
}
.rc-body { flex: 1; }
.rc-body h3 {
  color: var(--gray-900);
  margin-bottom: 0.4rem;
  font-size: 1.05rem;
}
.rc-body p {
  font-size: 0.9rem;
  line-height: 1.65;
}
.rc-arrow {
  color: var(--gray-300);
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: color 0.2s, transform 0.2s;
}
.research-card:hover .rc-arrow {
  color: var(--primary);
  transform: translateX(3px);
}

/* ---- News ---- */
.news-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.news-date {
  display: block;
  font-size: 0.75rem;
  color: var(--gray-400);
  font-weight: 500;
}
.news-title { font-size: 1rem; color: var(--gray-900); }
.news-summary { font-size: 0.875rem; line-height: 1.65; }

.section-cta {
  margin-top: var(--space-xl);
  text-align: center;
}

/* ---- Join section ---- */
.join-section {
  background: linear-gradient(135deg, var(--navy) 0%, #1E3A6E 50%, #2557A7 100%);
  padding: var(--space-2xl) 0;
}
.join-inner {
  max-width: 640px;
}
.join-content h2 {
  color: var(--white);
  margin-bottom: var(--space-sm);
}
.join-content p {
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: var(--space-lg);
}
.join-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

/* ---- Responsive ---- */
@media (max-width: 800px) {
  .mission-grid { grid-template-columns: 1fr; }
}

@media (max-width: 600px) {
  .hero { padding: var(--space-2xl) 0 var(--space-xl); }
  .hero-accent { display: none; }
}
</style>

<!-- Floating particle animation (light theme: blue dots on white) -->
<script>
const canvas = document.getElementById('particles') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d');
  let w = 0, h = 0;

  interface Particle {
    x: number; y: number; vx: number; vy: number;
    r: number; a: number; pulse: number; speed: number;
  }

  const particles: Particle[] = [];
  const COUNT = 50;

  function resize() {
    w = canvas.width = canvas.offsetWidth;
    h = canvas.height = canvas.offsetHeight;
  }

  function init() {
    resize();
    for (let i = 0; i < COUNT; i++) {
      const speed = 0.12 + Math.random() * 0.2;
      const angle = Math.random() * Math.PI * 2;
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 1 + Math.random() * 2,
        a: 0.08 + Math.random() * 0.18,
        pulse: Math.random() * Math.PI * 2,
        speed: 0.006 + Math.random() * 0.012,
      });
    }
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, h);

    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.pulse += p.speed;

      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;

      const alpha = p.a * (0.5 + 0.5 * Math.sin(p.pulse));

      // Soft glow
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha * 0.08})`;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(12, 35, 75, ${alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  init();
  draw();
  window.addEventListener('resize', resize);
}
</script>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
