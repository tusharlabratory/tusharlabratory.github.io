---
import BaseLayout from '../layouts/BaseLayout.astro';
import resources from '../content/resources.json';

const base = import.meta.env.BASE_URL;
const typeOrder = ['Software', 'Dataset', 'Model'];
const grouped = typeOrder.map(t => ({
  type: t,
  items: resources.filter(r => r.type === t),
})).filter(g => g.items.length > 0);

function assetUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
---

<BaseLayout title="Resources">
  <section class="page-hero">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,0.5)">Tushar Lab</p>
      <h1>Resources</h1>
      <p>Open-source tools, datasets, and model weights from the lab — freely available to the research community.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {grouped.map(g => (
        <div class="resource-group">
          <h3 class="rg-title">{g.type === 'Software' ? '🛠 ' : g.type === 'Dataset' ? '🗄 ' : '🤖 '}{g.type}</h3>
          <div class="resources-grid">
            {g.items.map((r, i) => {
              const mainLink = r.link || r.github || r.paper || '';
              const CardTag = mainLink ? 'a' : 'div';
              return (
                <CardTag
                  href={mainLink || undefined}
                  target={mainLink ? '_blank' : undefined}
                  rel={mainLink ? 'noopener noreferrer' : undefined}
                  class={`resource-card reveal`}
                  style={`transition-delay:${i * 0.05}s`}
                >
                  <div class="resource-card-image">
                    <img src={assetUrl(r.image)} alt={r.title} />
                  </div>
                  <div class="resource-card-body">
                    <div class="resource-card-header">
                      <h4 class="resource-card-title">{r.title}</h4>
                      <span class={`tag tag--${r.type === 'Software' ? 'red' : r.type === 'Dataset' ? 'navy' : 'navy'}`}>{r.type}</span>
                    </div>
                    <p class="resource-card-desc">{r.description}</p>
                    <div class="resource-card-tags">
                      {r.tags.map(t => <span class="tag">{t}</span>)}
                    </div>
                    <div class="resource-card-links">
                      {r.github && <a href={r.github} class="btn btn-navy btn-sm" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">GitHub ↗</a>}
                      {r.paper && <a href={r.paper} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">Paper ↗</a>}
                      {mainLink && <span class="resource-card-link">View Resource &rarr;</span>}
                    </div>
                  </div>
                </CardTag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.resource-group {
  margin-bottom: var(--space-2xl);
}
.rg-title {
  font-size: 1.1rem;
  color: var(--navy);
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-xs);
  border-bottom: 2px solid var(--primary);
  display: inline-block;
}

/* ---- Resource card grid (matches project cards) ---- */
.resources-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}

a.resource-card {
  text-decoration: none;
  color: inherit;
}

.resource-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
}
.resource-card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(171, 5, 32, 0.15);
  transform: translateY(-3px);
}

.resource-card-image {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
}
.resource-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}
.resource-card:hover .resource-card-image img {
  transform: scale(1.03);
}

.resource-card-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.5rem;
}

.resource-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.5rem;
}

.resource-card-title {
  font-size: 1.1rem;
  color: var(--navy);
}

.resource-card-desc {
  font-size: 0.88rem;
  line-height: 1.65;
  flex: 1;
}

.resource-card-tags {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.resource-card-links {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  margin-top: auto;
}

.btn-sm {
  font-size: 0.8rem;
  padding: 0.5rem 1rem;
}

.resource-card-link {
  display: inline-flex;
  align-items: center;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--primary);
  gap: 0.25rem;
  margin-left: auto;
  transition: gap 0.2s ease;
}
.resource-card:hover .resource-card-link {
  gap: 0.5rem;
}

@media (max-width: 900px) {
  .resources-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .resources-grid { grid-template-columns: 1fr; }
}
</style>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
