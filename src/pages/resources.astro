---
import BaseLayout from '../layouts/BaseLayout.astro';
import resources from '../content/resources.json';

const base = import.meta.env.BASE_URL;

function assetUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
---

<BaseLayout title="Resources">
  <section class="page-hero">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,0.5)">Tushar Lab</p>
      <h1>Resources</h1>
      <p>Open-source tools, datasets, and models from the lab — freely available to the research community.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="resources-grid">
        {resources.map((r, i) => (
          <a
            href={r.link || r.github || '#'}
            class={`resource-card reveal`}
            style={`transition-delay:${i * 0.05}s`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="resource-card-image">
              <img src={assetUrl(r.image)} alt={r.title} />
            </div>
            <div class="resource-card-body">
              <h4 class="resource-card-title">{r.title}</h4>
              <p class="resource-card-desc">{r.description}</p>
              <span class="resource-card-link">{r.link?.includes('zenodo') ? 'View on Zenodo' : 'View on GitHub'} &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---- Resource card grid (project-style clickable cards) ---- */
.resources-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-lg);
}

.resource-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
}
.resource-card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(171, 5, 32, 0.15);
  transform: translateY(-3px);
}

.resource-card-image {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
}
.resource-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}
.resource-card:hover .resource-card-image img {
  transform: scale(1.03);
}

.resource-card-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.5rem;
}

.resource-card-title {
  font-size: 1.1rem;
  color: var(--navy);
}

.resource-card-desc {
  font-size: 0.88rem;
  line-height: 1.65;
  flex: 1;
}

.resource-card-link {
  display: inline-flex;
  align-items: center;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--primary);
  gap: 0.25rem;
  margin-top: auto;
  transition: gap 0.2s ease;
}
.resource-card:hover .resource-card-link {
  gap: 0.5rem;
}

@media (max-width: 600px) {
  .resources-grid { grid-template-columns: 1fr; }
}
</style>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
