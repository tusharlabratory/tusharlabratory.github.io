---
import BaseLayout from '../layouts/BaseLayout.astro';
import researchData from '../content/research.json';
const base = import.meta.env.BASE_URL;
const areas = researchData.areas;
const featured = researchData.featured;
const projects = researchData.projects;

function assetUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
---

<BaseLayout title="Research">

  <!-- ============================================================
       HERO — Research page header
  ============================================================ -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,0.5)">Tushar Lab</p>
      <h1>Research</h1>
      <p>We develop data-centric AI frameworks for healthcare and medicine — building tools, data, and evaluation methods that are clinically grounded, rigorously tested, and worthy of real-world trust.</p>
    </div>
  </section>

  <!-- ============================================================
       PART 1 — RESEARCH AREAS AS FLASHCARDS
  ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Work On</p>
        <h2>Research Areas</h2>
        <p>Our research spans four interconnected themes — from curating better data and building intelligent clinical tools, to leveraging simulation and synthetic data to advance healthcare AI.</p>
      </div>
      <div class="flashcard-grid">
        {areas.map((area, i) => (
          <div class={`flashcard reveal`} style={`transition-delay:${i * 0.07}s`}>
            <div class="flashcard-top">
              <div class={`flashcard-icon fc-theme-${i}`}>
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  {area.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                  {area.icon === 'brain' && <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z M9 22h6"/>}
                  {area.icon === 'monitor' && <><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></>}
                  {area.icon === 'layers' && <><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></>}
                </svg>
              </div>
              <span class={`flashcard-number fc-num-${i}`}>{`0${i + 1}`}</span>
            </div>
            <h3 class="flashcard-title">{area.title}</h3>
            <p class="flashcard-desc">{area.short}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       PART 2 — FEATURED PROJECTS
  ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Flagship Work</p>
        <h2>Featured Projects</h2>
        <p>Selected projects that represent our lab's core contributions — advancing how medical AI is built, evaluated, and trusted in clinical practice.</p>
      </div>
      <div class="featured-grid">
        {featured.map((project, i) => (
          <div class={`featured-card reveal`} style={`transition-delay:${i * 0.08}s`}>
            <div class="featured-image">
              <img src={assetUrl(project.image)} alt={project.title} />
            </div>
            <div class="featured-body">
              <div class="featured-header">
                <h3 class="featured-title">{project.title}</h3>
                <p class="featured-heading">{project.heading}</p>
              </div>
              <p class="featured-summary">{project.summary}</p>
              <div class="featured-impact">
                <span class="featured-impact-label">Why It Matters</span>
                <p>{project.impact}</p>
              </div>
              <a href={project.link} class="btn btn-outline featured-cta" target="_blank" rel="noopener noreferrer">View Project &rarr;</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       PART 3 — PROJECTS
  ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">All Projects</p>
        <h2>Research Portfolio</h2>
        <p>A broader view of ongoing and published work across the lab — from tools and datasets to evaluation frameworks and generative methods.</p>
      </div>
      <div class="projects-grid">
        {projects.map((project, i) => (
          <a href={project.link} class={`project-card reveal`} style={`transition-delay:${i * 0.05}s`} target="_blank" rel="noopener noreferrer">
            <div class="project-card-image">
              <img src={assetUrl(project.image)} alt={project.title} />
            </div>
            <div class="project-card-body">
              <h4 class="project-card-title">{project.title}</h4>
              <p class="project-card-heading">{project.heading}</p>
              <p class="project-card-desc">{project.description}</p>
              <span class="project-card-link">View Project &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       COLLABORATION CTA
  ============================================================ -->
  <section class="section section--navy">
    <div class="container collab-section">
      <div>
        <p class="section-label" style="color:rgba(255,255,255,0.5)">Collaboration</p>
        <h2>Interested in collaborating?</h2>
        <p>We welcome collaborations with clinical, industry, and academic partners. Reach out to discuss potential projects.</p>
      </div>
      <a href={`${base}contact/`} class="btn btn-primary">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
/* ---- Scroll reveal ---- */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================================
   PART 1 — FLASHCARD GRID
   ============================================================ */
.flashcard-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-lg);
}

.flashcard {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  position: relative;
  transition: box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, transform 0.35s ease;
}
.flashcard:hover {
  box-shadow: var(--shadow-lg);
  border-color: var(--gray-300);
  transform: translateY(-3px);
}

.flashcard-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.flashcard-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  transition: transform 0.3s ease;
}
.flashcard:hover .flashcard-icon {
  transform: scale(1.08);
}

/* Icon themes matching homepage */
.fc-theme-0 { background: rgba(171, 5, 32, 0.08); color: var(--primary); }
.fc-theme-1 { background: rgba(12, 35, 75, 0.08); color: var(--navy); }
.fc-theme-2 { background: rgba(37, 87, 167, 0.1); color: #2557A7; }
.fc-theme-3 { background: rgba(139, 0, 21, 0.08); color: var(--primary-dark); }

.flashcard-number {
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--gray-300);
}

.flashcard-title {
  font-size: 1.1rem;
  color: var(--gray-900);
  margin-bottom: 0.6rem;
}

.flashcard-desc {
  font-size: 0.9rem;
  line-height: 1.7;
  flex: 1;
}

@media (max-width: 600px) {
  .flashcard-grid { grid-template-columns: 1fr; }
}

/* ============================================================
   PART 2 — FEATURED PROJECTS
   ============================================================ */
.featured-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.featured-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  transition: box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.35s ease;
}
.featured-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.featured-image {
  width: 320px;
  flex-shrink: 0;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.featured-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.featured-body {
  padding: var(--space-lg);
  flex: 1;
}

.featured-header {
  margin-bottom: var(--space-sm);
}

.featured-title {
  font-size: 1.3rem;
  color: var(--navy);
  margin-bottom: 0.25rem;
}

.featured-heading {
  font-size: 0.9rem;
  color: var(--gray-500);
  font-weight: 500;
  margin-bottom: 0;
}

.featured-summary {
  font-size: 0.95rem;
  line-height: 1.75;
  margin-bottom: var(--space-md);
}

.featured-impact {
  background: var(--gray-50);
  border-left: 3px solid var(--primary);
  padding: var(--space-sm) var(--space-md);
  border-radius: 0 var(--radius) var(--radius) 0;
  margin-bottom: var(--space-md);
}

.featured-impact-label {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--primary);
  display: block;
  margin-bottom: 0.35rem;
}

.featured-impact p {
  font-size: 0.9rem;
  line-height: 1.7;
}

.featured-cta {
  margin-top: var(--space-xs);
}

@media (max-width: 700px) {
  .featured-card { flex-direction: column; }
  .featured-image { width: 100%; height: 200px; }
  .featured-body { padding: var(--space-md); }
}

/* ============================================================
   PART 3 — PROJECTS
   ============================================================ */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}

.project-card {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
}
.project-card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(171, 5, 32, 0.15);
  transform: translateY(-3px);
}

.project-card-image {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--gray-100);
}
.project-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}
.project-card:hover .project-card-image img {
  transform: scale(1.03);
}

.project-card-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  flex: 1;
}

.project-card-title {
  font-size: 1.1rem;
  color: var(--navy);
  margin-bottom: 0.2rem;
}

.project-card-heading {
  font-size: 0.8rem;
  color: var(--gray-500);
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.project-card-desc {
  font-size: 0.88rem;
  line-height: 1.65;
  flex: 1;
  margin-bottom: var(--space-sm);
}

.project-card-link {
  display: inline-flex;
  align-items: center;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--primary);
  gap: 0.25rem;
  margin-top: auto;
  transition: gap 0.2s ease;
}
.project-card:hover .project-card-link {
  gap: 0.5rem;
}

@media (max-width: 900px) {
  .projects-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .projects-grid { grid-template-columns: 1fr; }
}

/* ============================================================
   COLLABORATION SECTION
   ============================================================ */
.collab-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-xl);
}

@media (max-width: 800px) {
  .collab-section { flex-direction: column; align-items: flex-start; }
}
</style>

<!-- Scroll reveal observer -->
<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));
</script>
