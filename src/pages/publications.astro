---
import BaseLayout from '../layouts/BaseLayout.astro';
import pubs from '../content/publications.json';

const featured = pubs.filter(p => p.featured);
const years = [...new Set(pubs.map(p => p.year))].sort((a,b) => b - a);

/**
 * Format a publication in IEEE style:
 * Authors, "Title," Venue, vol. X, no. Y, pp. Z, Year.
 */
function ieeeRef(p: typeof pubs[0]): string {
  let ref = p.authors.join(', ');
  ref += `, "${p.title},"`;
  // venue is handled in JSX as italic
  return ref;
}

function ieeeVenueDetails(p: typeof pubs[0]): string {
  let details = '';
  if (p.volume) details += `, vol. ${p.volume}`;
  if (p.number) details += `, no. ${p.number}`;
  if (p.pages) details += `, pp. ${p.pages}`;
  details += `, ${p.year}.`;
  return details;
}
---

<BaseLayout title="Publications">
  <section class="page-hero">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,0.5)">Tushar Lab</p>
      <h1>Publications</h1>
      <p>Peer-reviewed research in medical imaging AI, virtual imaging trials, and computational evaluation.</p>
    </div>
  </section>

  <!-- Featured Publications -->
  {featured.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="section-label">Highlights</p>
          <h2>Featured Publications</h2>
        </div>
        <div class="featured-grid">
          {featured.map((p, i) => (
            <article class="featured-card">
              <div class="featured-accent"></div>
              <div class="featured-body">
                <p class="featured-citation">
                  {p.authors.join(', ')},
                  &ldquo;{p.title},&rdquo;
                  <em>{p.venue}</em>
                  {p.volume && <>, vol. {p.volume}</>}
                  {p.number && <>, no. {p.number}</>}
                  {p.pages && <>, pp. {p.pages}</>}
                  , {p.year}.
                </p>
                <div class="featured-links">
                  {p.doi && <a href={`https://doi.org/${p.doi}`} class="pub-link" target="_blank">DOI ↗</a>}
                  {p.pdf && <a href={p.pdf} class="pub-link" target="_blank">PDF ↗</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Publications -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">All Work</p>
        <h2>Publications</h2>
      </div>
      <div class="pubs-list">
        {years.map(year => (
          <div class="year-group">
            <div class="year-heading">{year}</div>
            {pubs.filter(p => p.year === year).map((p) => (
              <article class="pub-item">
                <div class="pub-number">[{pubs.indexOf(p) + 1}]</div>
                <div class="pub-body">
                  <p class="pub-citation">
                    {p.authors.join(', ')},
                    &ldquo;{p.title},&rdquo;
                    <em>{p.venue}</em>
                    {p.volume && <>, vol. {p.volume}</>}
                    {p.number && <>, no. {p.number}</>}
                    {p.pages && <>, pp. {p.pages}</>}
                    , {p.year}.
                  </p>
                  <div class="pub-links">
                    {p.doi && <a href={`https://doi.org/${p.doi}`} class="pub-link" target="_blank">DOI ↗</a>}
                    {p.pdf && <a href={p.pdf} class="pub-link" target="_blank">PDF ↗</a>}
                  </div>
                </div>
              </article>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ---- Featured Publications ---- */
.featured-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.featured-card {
  display: flex;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.featured-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.featured-accent {
  width: 4px;
  flex-shrink: 0;
  background: linear-gradient(180deg, var(--primary) 0%, var(--navy) 100%);
}

.featured-body {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.featured-citation {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--text);
}
.featured-citation em {
  font-style: italic;
  color: var(--navy);
  font-weight: 500;
}

.featured-links {
  display: flex;
  gap: var(--space-sm);
}

/* ---- All Publications ---- */
.year-group { margin-bottom: var(--space-xl); }
.year-heading {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--gray-200);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-xs);
  border-bottom: 1px solid var(--gray-200);
}

.pub-item {
  display: flex;
  gap: 0.75rem;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--gray-100);
  align-items: flex-start;
}
.pub-item:last-child { border-bottom: none; }

.pub-number {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--navy);
  flex-shrink: 0;
  min-width: 28px;
  padding-top: 2px;
}

.pub-body {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.pub-citation {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--text);
}
.pub-citation em {
  font-style: italic;
  color: var(--navy);
}

.pub-links, .featured-links { display: flex; gap: var(--space-sm); }
.pub-link {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--primary);
  transition: opacity 0.15s;
}
.pub-link:hover { opacity: 0.7; }
</style>
