---
import BaseLayout from '../layouts/BaseLayout.astro';
import pubs from '../content/publications.json';

const years = [...new Set(pubs.map(p => p.year))].sort((a,b) => b - a);
---

<BaseLayout title="Publications">
  <section class="page-hero">
    <div class="container">
      <p class="section-label" style="color:rgba(255,255,255,0.5)">Tushar Lab</p>
      <h1>Publications</h1>
      <p>Peer-reviewed research in medical imaging AI, virtual imaging trials, and computational evaluation.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pubs-list" id="pubs-list">
        {years.map(year => (
          <div class="year-group" data-year={year}>
            <div class="year-heading">{year}</div>
            {pubs.filter(p => p.year === year).map((p) => (
              <article class="pub-item">
                <div class="pub-number">[{pubs.indexOf(p) + 1}]</div>
                <div class="pub-body">
                  <p class="pub-citation">
                    {p.authors.join(', ')},
                    &ldquo;{p.title},&rdquo;
                    <em>{p.venue}</em>,
                    {p.year}.
                  </p>
                  <div class="pub-links">
                    {p.doi && <a href={`https://doi.org/${p.doi}`} class="pub-link" target="_blank">DOI ↗</a>}
                    {p.pdf && <a href={p.pdf} class="pub-link" target="_blank">PDF ↗</a>}
                  </div>
                </div>
              </article>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Publication list */
.year-group { margin-bottom: var(--space-xl); }
.year-heading {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--gray-200);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-xs);
  border-bottom: 1px solid var(--gray-200);
}

.pub-item {
  display: flex;
  gap: 0.75rem;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--gray-100);
  align-items: flex-start;
}
.pub-item:last-child { border-bottom: none; }

.pub-number {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--navy);
  flex-shrink: 0;
  min-width: 28px;
  padding-top: 2px;
}

.pub-body {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.pub-citation {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--text);
}
.pub-citation em {
  font-style: italic;
  color: var(--navy);
}

.pub-links { display: flex; gap: var(--space-sm); }
.pub-link {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--primary);
  transition: opacity 0.15s;
}
.pub-link:hover { opacity: 0.7; }
</style>
