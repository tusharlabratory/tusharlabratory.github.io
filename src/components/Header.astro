---
import site from '../content/site.json';
const base = import.meta.env.BASE_URL;
const navLinks = [
  { label: 'Research',     href: `${base}research/` },
  { label: 'Publications', href: `${base}publications/` },
  { label: 'Team',         href: `${base}team/` },
  { label: 'Resources',    href: `${base}resources/` },
  { label: 'News',         href: `${base}news/` },
  { label: 'Opportunities',href: `${base}opportunities/` },
  { label: 'Contact',      href: `${base}contact/` },
];
---

<header class="site-header" id="site-header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href={base} class="logo">
      <img src={`${base}logo-monogram.svg`} alt="Tushar Lab" class="logo-mark" width="34" height="34" />
      <span class="logo-text">
        <span class="logo-name">{site.labName}</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Primary">
      {navLinks.map(l => (
        <a class="nav-link" href={l.href}>{l.label}</a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav class="nav-mobile" id="nav-mobile" aria-hidden="true">
    {navLinks.map(l => (
      <a class="nav-mobile-link" href={l.href}>{l.label}</a>
    ))}
  </nav>
</header>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg-glass);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid var(--border);
  height: var(--nav-h);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
}

/* Logo */
.logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
}

.logo-mark {
  flex-shrink: 0;
  border-radius: 6px;
}

.logo-text {
  display: flex;
  flex-direction: column;
}
.logo-name {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: 1.15rem;
  color: var(--white);
  letter-spacing: 0.01em;
}

/* Desktop nav */
.nav-desktop {
  display: flex;
  align-items: center;
  gap: 0.1rem;
}
.nav-link {
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 400;
  color: var(--text-muted);
  padding: 0.4rem 0.7rem;
  border-radius: var(--radius);
  transition: color 0.2s, background 0.2s;
  text-decoration: none;
  white-space: nowrap;
}
.nav-link:hover {
  color: var(--white);
  background: rgba(255,255,255,0.05);
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.hamburger span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--text-muted);
  border-radius: 2px;
  transition: 0.25s;
}

/* Mobile nav */
.nav-mobile {
  display: none;
  flex-direction: column;
  background: var(--bg-glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: var(--space-xs) 0 var(--space-sm);
  border-top: 1px solid var(--border);
}
.nav-mobile.open { display: flex; }
.nav-mobile-link {
  padding: 0.7rem var(--space-lg);
  color: var(--text-muted);
  font-size: 0.9rem;
  font-weight: 400;
  transition: background 0.15s, color 0.15s;
  text-decoration: none;
}
.nav-mobile-link:hover { background: rgba(255,255,255,0.04); color: var(--white); }

@media (max-width: 860px) {
  .nav-desktop { display: none; }
  .hamburger { display: flex; }
  .site-header { height: auto; }
}
</style>

<script>
const btn = document.getElementById('hamburger');
const nav = document.getElementById('nav-mobile');
btn?.addEventListener('click', () => {
  const open = nav?.classList.toggle('open');
  btn.setAttribute('aria-expanded', String(open));
  nav?.setAttribute('aria-hidden', String(!open));
});
</script>
