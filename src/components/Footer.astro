---
import site from '../content/site.json';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <img src={`${base}logo-monogram.svg`} alt="Tushar Lab" class="footer-logo" width="36" height="36" />
      <div>
        <div class="footer-lab">{site.labName}</div>
        <div class="footer-dept">{site.department}</div>
      </div>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <div class="footer-col-title">Research</div>
        <a href={`${base}research/`}>Medical Imaging AI</a>
        <a href={`${base}research/`}>Virtual Imaging Trials</a>
        <a href={`${base}research/`}>Data-Centric AI</a>
        <a href={`${base}research/`}>Synthetic Imaging</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Lab</div>
        <a href={`${base}team/`}>Team</a>
        <a href={`${base}publications/`}>Publications</a>
        <a href={`${base}resources/`}>Resources</a>
        <a href={`${base}news/`}>News</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Connect</div>
        <a href={`${base}opportunities/`}>Opportunities</a>
        <a href={`${base}contact/`}>Contact</a>
        <a href={site.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; {year} {site.labName} &middot; Department of Radiology and Imaging Sciences &middot; University of Arizona &middot; Tucson, AZ</span>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--bg-deep);
  border-top: 1px solid var(--border);
  color: var(--text-dim);
  padding-top: var(--space-2xl);
  font-size: 0.875rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: var(--space-xl);
  padding-bottom: var(--space-2xl);
}

.footer-brand {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}

.footer-logo {
  flex-shrink: 0;
  border-radius: 6px;
}

.footer-lab {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--white);
  line-height: 1.3;
}
.footer-dept { font-size: 0.75rem; color: var(--text-dim); margin-top: 3px; }

.footer-cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.footer-col-title {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.2rem;
}

.footer-col a {
  color: var(--text-dim);
  font-size: 0.84rem;
  text-decoration: none;
  transition: color 0.2s;
  line-height: 1.5;
}
.footer-col a:hover { color: var(--cardinal); }

.footer-bottom {
  border-top: 1px solid var(--border);
  padding: var(--space-sm) 0;
}
.footer-bottom-inner {
  font-size: 0.72rem;
  color: var(--text-dim);
  text-align: center;
}

@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr; }
  .footer-cols { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 480px) {
  .footer-cols { grid-template-columns: 1fr; }
}
</style>
